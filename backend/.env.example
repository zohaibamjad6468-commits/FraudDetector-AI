APP_NAME=FinGuard AI Backend
APP_ENV=development
FLASK_ENV=development
FLASK_APP=run.py
FLASK_RUN_HOST=127.0.0.1
FLASK_RUN_PORT=5000

API_PREFIX=/api/v1
SECRET_KEY=replace-with-a-long-random-secret
JWT_SECRET_KEY=replace-with-a-different-long-random-secret
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Prefer DATABASE_URL in deployed environments.
# Example:
# DATABASE_URL=mysql+pymysql://fraud_user:strong_password@127.0.0.1:3306/fraud_detection
DATABASE_URL=

# Used when DATABASE_URL is empty.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=fraud_detection
MYSQL_USER=fraud_user
MYSQL_PASSWORD=strong_password

SQLALCHEMY_POOL_RECYCLE=280
